    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.075" />
      </geometry>
    </collision>
  </link>
  <joint name="back_left_wheel_joint" type="continuous">
    <origin xyz="-0.2305 0.26325 -0.035" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="back_left_wheel" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- Back Right Wheel -->
  <link name="back_right_wheel">
    <inertial>
      <origin xyz="5.58348600632197E-07 1.3626034917058E-07 -0.0233700496011711" rpy="0 0 0" />
      <mass value="0.181848128778831" />
      <inertia ixx="9.38369979810421E-05" ixy="8.02094977130252E-08" ixz="-7.70699508241563E-07" iyy="9.36898637208611E-05" iyz="-4.18369878868712E-07" izz="0.00016398149673665" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="-1.5708 0 0" />
      <geometry>
        <mesh filename="file://$(find bot)/meshes/back_right_wheel_X3.STL" scale="2.322 2.322 2.322" />
      </geometry>
      <material name=""><color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.075" />
      </geometry>
    </collision>
  </link>
  <joint name="back_right_wheel_joint" type="continuous">
    <origin xyz="-0.23 -0.26325 -0.035" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="back_right_wheel" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- Wheel friction properties -->
  <gazebo reference="front_left_wheel">
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>0.2</mu2>
            <fdir1 ignition:expressed_in="base_footprint">1 -1 0</fdir1>
            <slip1>0.01</slip1>
            <slip2>0.01</slip2>
          </ode>
        </friction>
        <contact>
          <ode>
            <kp>10000000.0</kp>
            <kd>100.0</kd>
            <max_vel>1.0</max_vel>
            <min_depth>0.001</min_depth>
          </ode>
        </contact>
      </surface>
    </collision>
  </gazebo>

  <gazebo reference="front_right_wheel">
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>0.2</mu2>
            <fdir1 ignition:expressed_in="base_footprint">1 1 0</fdir1>
            <slip1>0.01</slip1>
            <slip2>0.01</slip2>
          </ode>
        </friction>
        <contact>
          <ode>
            <kp>10000000.0</kp>
            <kd>100.0</kd>
            <max_vel>1.0</max_vel>
            <min_depth>0.001</min_depth>
          </ode>
        </contact>
      </surface>
    </collision>
  </gazebo>

